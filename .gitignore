# .gitignore for Python + AWS Lambda project
# Exclude virtualenvs, caches, IDE files, OS junk, build artifacts and secrets

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.Python
.python-version

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
pip-log.txt
wheelhouse/

# AWS / serverless / Lambda build artifacts
.aws-sam/
.serverless/
.chalice/
*.zip
*.jar
*.war
lambda-package.zip

# IDEs / editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# macOS / Windows files
.DS_Store
Thumbs.db
desktop.ini

# Tests / coverage / type checking
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
.pytype/

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.cache

# MLflow / evaluation outputs
mlruns/
mlartifacts/
mlflow.db
mlflow.db-shm
mlflow.db-wal
evals/outputs/
evals/results/

# Build / packaging artifacts
package/
*.backup

# Scratch / debug / one-off files
response.txt
run.txt
bedrock_trace.py

# Deprecated docs (kept in git history)
DEPLOYMENT_STATUS.md
DEPLOYMENT_SUCCESS.md
DEPLOYMENT_GUIDE.md
scripts/SCRIPTS_UPDATE_SUMMARY.md
scripts/DEPLOYMENT_LESSONS.md
scripts/deploy.ps1.backup
scripts/README2.md

# Sensitive / credential files
.env
.env.*
!.env.example
evals/dagshub.env
secrets.yml
credentials.json
aws_credentials
.aws/credentials
.aws/config

# Jupyter
.ipynb_checkpoints

# Node / frontend
node_modules/
npm-debug.log
yarn-error.log

# Database / local files
*.sqlite3
*.db
*.pem

# Misc
__MACOSX/
*.class

# Project-specific sensitive / test files
# - test payloads and deployment configs that may contain account IDs or secrets
test-payload.json
*.payload.json
deployment/*.json
DEPLOYMENT_*.md

# If you already committed files that should be ignored, run:
#   git rm -r --cached .
#   git add .
#   git commit -m "Add .gitignore"
scripts/update-lambda.ps1
run
evals/results
evals/*.json
run.txt
Guide/
scripts/
!scripts/
scripts/*
!scripts/job-agent-backend.png
.goose
.agents
skills-lock.json
Mermaid/
*.mmd
Mermaid/ai_agent_architecture.mmd
Mermaid/*.mmd
OPTIMIZATION/
.amazonq/
MLFLOW_STEPS/run_opnow_pipeline.py
evals/results/
*.svg
