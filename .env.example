APP_NAME=Job Agent Backend
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# AWS / Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MAX_TOKENS=1024
BEDROCK_TEMPERATURE=0.7
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
EMBED_DIMENSION=512

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS
CORS_ORIGINS=http://localhost:3000,https://your-frontend.example.com

# CV storage
S3_CV_BUCKET=your-cv-bucket

# MLflow
MLFLOW_TRACKING_URI=https://your-mlflow-server.example.com
MLFLOW_EXPERIMENT_NAME=job-agent-backend-production
MLFLOW_ACTIVE_MODEL_NAME=job-agent-backend
MLFLOW_TRACE_TAG_KEY=trace_purpose
MLFLOW_TRACE_TAG_VALUE=production
MLFLOW_TRACKING_URI_FALLBACK=
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://your-mlflow-artifacts/path
MLFLOW_SPOOL_ENABLED=true
MLFLOW_SPOOL_BUCKET=your-mlflow-spool-bucket
MLFLOW_SPOOL_PREFIX=mlflow-spool
MLFLOW_SPOOL_FLUSH_TOKEN=
MLFLOW_SPOOL_AUTOFLUSH_MAX_ITEMS=0
